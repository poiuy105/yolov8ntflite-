<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="MQTT配置">

        <EditTextPreference
            app:key="mqtt_broker"
            app:title="Broker地址"
            app:defaultValue="192.168.123.49"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            app:key="mqtt_port"
            app:title="端口"
            app:defaultValue="1883"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            app:key="mqtt_topic"
            app:title="Topic"
            app:defaultValue="home/camera/person_count"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            app:key="mqtt_username"
            app:title="用户名"
            app:defaultValue="fnos"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            app:key="mqtt_password"
            app:title="密码"
            app:defaultValue="fuckfnos"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory app:title="检测配置">

        <ListPreference
            app:key="inference_fps"
            app:title="推理帧率"
            app:defaultValue="2"
            app:entries="@array/fps_entries"
            app:entryValues="@array/fps_values"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            app:key="enable_preview"
            app:title="显示相机预览"
            app:defaultValue="true" />

    </PreferenceCategory>

    <PreferenceCategory app:title="省电与保护">

        <SwitchPreferenceCompat
            app:key="thermal_protection"
            app:title="温度保护"
            app:summary="过热时自动降频或暂停"
            app:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="power_save_mode"
            app:title="省电模式"
            app:summary="未充电时自动降低帧率"
            app:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="auto_dim_screen"
            app:title="自动降低亮度"
            app:summary="启动后30秒自动降低屏幕亮度"
            app:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="night_mode"
            app:title="夜间模式"
            app:summary="暗光环境自动降低帧率"
            app:defaultValue="true" />

    </PreferenceCategory>

    <PreferenceCategory app:title="高级配置">

        <EditTextPreference
            app:key="heartbeat_interval"
            app:title="心跳间隔 (秒)"
            app:defaultValue="30"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            app:key="auto_start_on_boot"
            app:title="开机自启"
            app:defaultValue="false" />

        <SwitchPreferenceCompat
            app:key="enable_watchdog"
            app:title="启用心跳"
            app:defaultValue="true" />

    </PreferenceCategory>

</PreferenceScreen>
